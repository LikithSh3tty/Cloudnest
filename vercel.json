{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "backend/**" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
